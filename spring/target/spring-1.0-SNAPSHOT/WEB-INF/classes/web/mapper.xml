<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapperment 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="web.dao.Dao">
    <update id="update">
        update account set money = #{money} where name = #{name};
    </update>

    <select id="selectAccount" resultType="web.pojo.Account">
        select * from account where name = #{name};
    </select>

    <select id="selectAll" resultType="web.pojo.Account">
        select * from account;
    </select>

</mapper>