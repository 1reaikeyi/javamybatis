<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapperment 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="many.Onemapper">
<!--一对一关系 -->
    <resultMap id="student" type="many.One">
        <id property="sid" column="sid"/>
        <result property="sname" column="sname"/>
        <result property="subject" column="subject"/>
        <result property="two.tid" column="tid"/>
        <result property="two.tname" column="tname"/>
    </resultMap>
    <select id="studentById" resultMap="student">
        select student.sname,teacher.tname
        from student
        right outer join class on student.sid = class.sid
        inner join teacher on teacher.tid = class.tid where student.sid = #{id};
    </select>
<!-- 分布1-->
    <select id="studentStep" resultMap="student_step">
        select student.sid, student.sname, class.tid
        from student
        inner join class on student.sid = class.sid
        where student.sid = #{id}
    </select>
    <resultMap id="student_step" type="many.One">
        <id property="sid" column="sid"/>
        <result property="sname" column="sname"/>
        <association property="two" select="many.Twomapper.studentStep" column="tid" fetchType="eager"/>
    </resultMap>
<!--一对多关系-->
    <select id="teacherStep" resultType="many.One">
        select student.sname
        from student
        where student.sid = #{sid}
    </select>





</mapper>
    