<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration
        PUBLIC "-//mybatis.org//DTD jdbcTemplate.Config 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>

    <properties resource="resource.properties"></properties>

    <settings>
        <setting name="logImpl" value="SLF4J"/>
<!--        延迟加载-->
        <setting name="lazyLoadingEnabled" value="false"/>
<!--        二级缓存-->
<!--        默认似乎true-->
        <setting name="cacheEnbled" value="true"/>
    </settings>

<!--    起别名-->
    <typeAliases>
        <typeAlias type="resource.Usee" alias="Usee"/>
    </typeAliases>

    <environments default="develop">
        <environment id="develop">
            <transactionManager type="JDBC"/>
            <dataSource type="UNPOOLED">
                <property name="driver" value="${mybatis.driver}"/>
                <property name="url" value="${mybatis.url}"/>
                <property name="username" value="${mybatis.username}"/>
                <property name="password" value="${mybatis.password}"/>
            </dataSource>
        </environment>

    </environments>
    <mappers>
        <mapper resource="CRUD.xml"/>
        <mapper resource="annotation.xml"/>
        <mapper resource="$.xml"/>
        <mapper resource="map.xml"/>
        <mapper resource="dynamic.xml"/>
        <mapper resource="all.xml"/>
        <mapper resource="many/onemapper.xml"/>
        <mapper resource="many/twomapper.xml"/>
    </mappers>

</configuration>