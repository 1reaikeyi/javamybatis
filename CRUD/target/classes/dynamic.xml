<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapperment 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="dynamic.Dao">
    <select id="selectIf" resultType="Usee">
        select name, workplace, salary from shuihu
        <where>
            <if test="name != null and name != ''">and name = #{name}</if>
            <if test="salary != null">and salary >= #{salary}</if>
            <if test="workplace != null and workplace != ''">and workplace = #{workplace}</if>
        </where>
    </select>

    <select id="selectTrim" resultType="Usee">
        select name, workplace, salary from shuihu
        <trim prefix="where" prefixOverrides="and||or">
            <if test="name != null and name != ''">
                and name = #{name}
            </if>
            <if test="salary != null">
                and salary >= #{salary}
            </if>
            <if test="workplace != null and workplace != ''">
                 and workplace = #{workplace}
            </if>
        </trim>
    </select>

    <update id="updateSet">
    update shuihu
        <set> salary = #{salary},workplace = #{workplace} </set>
    where name = #{name};
    </update>

    <delete id="deleteForeach">
    delete from shuihu where id in
        <foreach collection="ids" open="(" close=")" item="idem" separator=",">
        #{idem}
        </foreach>
    </delete>

    <insert id="insertForeach">
    insert into shuihu (name,id,workplace,salary,gender,job) values
        <foreach collection="list" item="values" separator=",">
        (#{values.name},#{values.id},#{values.workplace},#{values.salary},#{values.gender},#{values.job})
        </foreach>
    </insert>
</mapper>
    