<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="bmybatis.Dao">


    <insert id="insert">
        insert into accountServer(name,money) values (#{accountant},#{money});
    </insert>
    <update id="update">
        update accountServer set money=#{money} where name=#{accountant};
    </update>
    <delete id="delete">
        delete from accountServer where name=#{accountant};
    </delete>
    <select id="selectById" resultType="bmybatis.AccountServer">
        select money, name as accountant from accountServer where name = #{accountant};
    </select>
    <select id="selectAll" resultType="bmybatis.AccountServer">
        select money, name as accountant from accountServer;
    </select>



</mapper>