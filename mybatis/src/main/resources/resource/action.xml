<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="action">

    <!-- 查询所有用户 -->
    <select id="getAllUsers" resultType="function.Usee">
        select * from shuihu ;
    </select>

    <select id="getUserById" resultType="function.Usee">
        select * from shuihu where id = #{id};
    </select>



</mapper>